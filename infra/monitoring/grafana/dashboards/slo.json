{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "Anime RAG — SLO Dashboard",
  "uid":   "anime-rag-slo",
  "tags":  ["slo", "production"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "p95 Recommend Latency",
      "description": "SLO: < 15 000 ms",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 8000 },
              { "color": "red",    "value": 15000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler='/api/v1/recommend'}[5m])) by (le)) * 1000",
        "legendFormat": "p95 ms"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "description": "SLO: < 1 %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red",    "value": 0.01 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(http_requests_total{handler=~'/api/v1/recommend.*',status=~'5..'}[5m])) / sum(rate(http_requests_total{handler=~'/api/v1/recommend.*'}[5m]))",
        "legendFormat": "error rate"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache Hit Rate",
      "description": "Informational — higher = lower cost",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green",  "value": 0.4 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rate(rag_requests_total{cached='true'}[5m])) / sum(rate(rag_requests_total[5m]))",
        "legendFormat": "hit rate"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cost / Hour (USD)",
      "description": "Rolling 1-hour LLM cost",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(rag_cost_usd_total[1h]))",
        "legendFormat": "$/hr"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Recommend Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler='/api/v1/recommend'}[2m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler='/api/v1/recommend'}[2m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler='/api/v1/recommend'}[2m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate & Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "errors/s" },
            "properties": [{ "id": "custom.axisPlacement", "value": "right" },
                           { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{handler=~'/api/v1/recommend.*'}[1m]))",
          "legendFormat": "req/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{handler=~'/api/v1/recommend.*',status=~'5..'}[1m]))",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token Usage by Model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(rag_tokens_total{token_type='input'}[5m])) by (model)",
          "legendFormat": "{{model}} in"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(rag_tokens_total{token_type='output'}[5m])) by (model)",
          "legendFormat": "{{model}} out"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cumulative Cost USD",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(rag_cost_usd_total) by (model)",
        "legendFormat": "{{model}}"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "DB Connection Pool — Active / Idle / Waiting",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "pgbouncer_pools_cl_active{database='anime_rag'}",
          "legendFormat": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "pgbouncer_pools_cl_waiting{database='anime_rag'}",
          "legendFormat": "waiting"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "pgbouncer_pools_sv_idle{database='anime_rag'}",
          "legendFormat": "srv idle"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Redis — Cache Operations / s",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 1 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(redis_commands_total{cmd='get'}[1m])",
          "legendFormat": "GET/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(redis_commands_total{cmd='set'}[1m])",
          "legendFormat": "SET/s"
        }
      ]
    }
  ]
}
