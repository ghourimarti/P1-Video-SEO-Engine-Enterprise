# Copy to .env — never commit .env
# ─── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # used for embeddings (text-embedding-3-large)
COHERE_API_KEY=your_cohere_api_key_here          # used for reranker

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=anime_rag
POSTGRES_USER=anime_rag
POSTGRES_PASSWORD=change_me_in_prod

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Observability ───────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=anime-rag-api

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO
API_PORT=8000
API_HOST=0.0.0.0

# ─── LiteLLM routing ─────────────────────────────────────────────────────────
DEFAULT_MODEL=claude-sonnet-4-6
CHEAP_MODEL=claude-haiku-4-5-20251001
FALLBACK_MODEL=groq/llama-3.1-8b-instant
EMBEDDING_MODEL=text-embedding-3-large

# ─── AWS (IaC only — no real spend in dev) ───────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
